{
  "name": "doccano-frontend",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "oxlint --fix",
    "format": "oxfmt --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "turbo": "^2.10.0",
    "typescript": "5.9.2",
    "vitepress": "^2.0.0-alpha.17"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": {
   "packages":[
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "vue": "^3.5.38"
  }
}
}
